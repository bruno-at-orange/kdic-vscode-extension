{
  "name": "khiops-kdic",
  "displayName": "Khiops Dictionary (.kdic)",
  "description": "Syntax highlighting and IntelliSense for Khiops dictionary files (.kdic)",
  "version": "0.1.0",
  "publisher": "khiopsml",
  "license": "BSD-3-Clause-Clear",
  "repository": {
    "type": "git",
    "url": "https://github.com/KhiopsML/khiops.git"
  },
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "images/khiops.png",
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "kdic",
        "aliases": [
          "Khiops Dictionary",
          "kdic"
        ],
        "extensions": [
          ".kdic"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/khiops.png",
          "dark": "./images/khiops.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "kdic",
        "scopeName": "source.kdic",
        "path": "./syntaxes/kdic.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kdic",
        "path": "./snippets/kdic.code-snippets"
      }
    ],
    "configuration": {
      "id": "kdic",
      "title": "Khiops Dictionary",
      "order": 1,
      "properties": {
        "kdic.khiopsPath": {
          "type": "string",
          "order": 5,
          "default": "",
          "description": "Explicit path to the Khiops binary. If empty, auto-detects from KHIOPS_HOME/bin/khiops (or KHIOPS_HOME\\bin\\khiops.cmd on Windows) and /usr/bin/khiops on macOS/Linux."
        },
        "kdic.enableKhiopsValidation": {
          "type": "boolean",
          "order": 1,
          "default": true,
          "description": "Run Khiops on save to validate dictionary files."
        },
        "kdic.diagnosticSource": {
          "type": "string",
          "order": 2,
          "default": "both",
          "enum": [
            "khiops",
            "extension",
            "both"
          ],
          "enumDescriptions": [
            "Show only Khiops native errors (requires Khiops binary)",
            "Show only built-in extension errors",
            "Show errors from both Khiops and the built-in extension"
          ],
          "description": "Which diagnostic source to display in the Problems pane."
        },
        "kdic.runKhiopsOnAutoSave": {
          "type": "boolean",
          "order": 3,
          "default": true,
          "description": "Run Khiops validation on auto-save events too. Set to false for very large dictionary files."
        },
        "kdic.enableDebugTraces": {
          "type": "boolean",
          "order": 4,
          "default": false,
          "description": "Enable verbose Khiops debug traces in the Khiops output channel."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "smoke-test": "node scripts/smoke-test.js",
    "smoke-test:errors": "node scripts/smoke-test.js --errors-only"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  }
}